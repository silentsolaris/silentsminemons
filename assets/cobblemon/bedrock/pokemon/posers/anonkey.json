 "animations": {
   "faint": "q.bedrock_primary('anonkey', 'faint', q.curve('one'))",
   "cry": "q.bedrock_stateful('anonkey', 'cry')",
   "recoil": "q.bedrock_stateful('anonkey', 'recoil')",
   "physical": "q.bedrock_primary('anonkey', 'physical', q.curve('symmetrical_wide'))",
   "special": "q.bedrock_primary('anonkey', 'special', q.curve('symmetrical_wide'))",
   "status": "q.bedrock_primary('anonkey', 'status', q.curve('symmetrical_wide'))"
 },
 "poses": {
   "standing": {
     "poseName": "standing",
     "transformTicks": 10,
     "poseTypes": [
       "STAND",
       "NONE",
       "PORTRAIT",
       "PROFILE"
     ],
     "animations": [
       "look",
       "bedrock(anonkey, ground_idle)"
     ],
     "quirks": [
       "q.bedrock_quirk('anonkey', 'blink')"
     ]
   },
   "walking": {
     "poseTypes": ["WALK"],
     "condition": "!q.in_air && !q.is_sprinting",
     "animations": [
       "q.look('head')",
       "q.bedrock('anonkey', 'ground_walk')",
       {
          "condition": "q.is_ridden",
          "animation": "q.bedrock('anonkey', 'ride_ground_walk')"
        }

     ],
     "quirks": ["q.bedrock_quirk('anonkey', 'blink')"]
   },
   "running": {
      "poseTypes": ["WALK", "FLOAT", "SWIM"],
      "condition": "!q.in_air && q.is_sprinting",
      "animations": [
        "q.look('head')",
        "q.bedrock('anonkey', 'ground_run')",
        {
          "condition": "q.is_ridden",
          "animation": "q.bedrock('anonkey', 'ride_ground_run')"
        }
      ],
      "quirks": ["q.bedrock_quirk('anonkey', 'blink')"]
    },
    "sleep": {
     "poseTypes": ["SLEEP"],
     "animations": ["q.bedrock('anonkey', 'sleep')"]
   }
	}
}